class Solution {
public:
    vector<int> singleNumber(vector<int>& nums) {
        sort(nums.begin(), nums.end());
        vector<int> ans;
        int n = nums.size();
        for (int i = 0; i < n; i++) {
            if (i + 1 < n && nums[i] == nums[i + 1]) i++; //skipping one more element bcoz it is same as prev
            else {
                ans.push_back(nums[i]); //diff no.
            }
        }
        return ans;
    }
};
