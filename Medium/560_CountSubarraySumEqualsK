class Solution {
public:
    int subarraySum(vector<int>& nums, int k) {
      int n = nums.size();
      unordered_map<int,int> mpp;
      int count = 0,prefix = 0;
      mpp[0] = 1;
      for(int i = 0;i < n;i++){
        prefix += nums[i];
        int remove = prefix - k;   //by this we will check which one to remove
        count += mpp[remove]; //increment count(by how many can be removed)
        mpp[prefix] += 1;    //update map to next element
      }  
      return count;
    }
};




