class Solution {
public:
    int flip(int n) {
        int count = 0;
        while (n > 0) {
            count++;
            n = (n & (n - 1));
        }
        return count;
    }
    int minBitFlips(int start, int goal) {
     int ans = start ^ goal;   // after xor idx where is 1 is where we need to change (it counts no. of setbits)
     return flip(ans);
    }
};
